<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=5">
    <title>MiFarmacia - TU FARMACIA DIGITAL</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root {
            --bg-main: #030712;
            --bg-card: rgba(31, 41, 55, 0.4);
            --bg-input: #0b0f19;
            --primary: #02f90a;
            --text-main: #f9fafb;
            --text-muted: #9ca3af;
            --success: #10b981;
            --danger: #ff1744;
            --radius-xl: 24px;
            --radius-md: 12px;
        }

        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: 'Plus Jakarta Sans', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }
        
        html {
            scroll-behavior: smooth;
        }

        body { 
            background: #030712 linear-gradient(145deg, #030712 0%, #0b1329 100%); 
            color: var(--text-main); 
            min-height: 100vh; 
            padding-bottom: 120px;
            overflow-x: hidden;
            font-size: 16px;
        }
        
        /* ===== HEADER ===== */
        header { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            padding: 12px 3%;
            background: rgba(3, 7, 18, 0.95); 
            backdrop-filter: blur(12px); 
            border-bottom: 2px solid rgba(2, 249, 10, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
            gap: 8px;
            flex-wrap: wrap;
        }

        .logo { 
            font-size: 16px; 
            font-weight: 800; 
            color: #fff; 
            display: flex; 
            align-items: center; 
            gap: 6px;
            min-width: fit-content;
            flex: 0 0 auto;
        }
        
        .logo span { 
            color: var(--primary); 
            text-shadow: 0 0 15px var(--primary); 
        }

        .header-center {
            display: flex;
            align-items: center;
            gap: 6px;
            background: rgba(2, 249, 10, 0.08);
            padding: 6px 10px;
            border-radius: 20px;
            border: 1px solid rgba(2, 249, 10, 0.3);
            flex: 1;
            min-width: 140px;
            max-width: 240px;
            margin: 0 auto;
        }

        .header-center label {
            font-size: 10px;
            font-weight: 700;
            color: var(--primary);
            white-space: nowrap;
        }

        .header-center select {
            background: transparent;
            border: none;
            color: var(--primary);
            font-weight: 700;
            outline: none;
            cursor: pointer;
            font-size: 11px;
            flex: 1;
            min-width: 0;
        }

        .header-right {
            display: flex;
            gap: 6px;
            align-items: center;
            flex: 0 0 auto;
        }

        #lblSaludo {
            font-size: 11px;
            color: var(--text-muted);
            white-space: nowrap;
            display: none;
            max-width: 120px;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        #btnPerfilToggle,
        #btnAuth,
        #btnCarrito {
            font-size: 11px;
            padding: 8px 10px !important;
            white-space: nowrap;
            min-height: 32px;
            position: relative;
        }

        .cart-badge {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--danger);
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
        }

        /* ===== MAIN CONTAINER ===== */
        .main-container { 
            width: 100%; 
            max-width: 100%; 
            margin: 0; 
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        /* ===== CATALOG SECTION ===== */
        .catalog-section { 
            display: flex; 
            flex-direction: column; 
            gap: 12px;
            padding: 12px 3%;
        }

        .search-box { 
            width: 100%; 
            display: flex; 
            gap: 8px; 
            background: var(--bg-card); 
            padding: 8px; 
            border-radius: 10px; 
            border: 1px solid rgba(2, 249, 10, 0.2);
        }

        .search-box input { 
            flex: 1; 
            background: transparent; 
            border: none; 
            outline: none; 
            padding: 10px; 
            color: #fff; 
            font-size: 14px;
            min-width: 0;
        }

        .search-box input::placeholder {
            font-size: 13px;
            color: var(--text-muted);
        }

        /* ===== CATEGORY PILLS ===== */
        .category-pills { 
            display: flex; 
            gap: 8px; 
            overflow-x: auto; 
            padding: 8px 0 6px 0;
            margin: 0 -3%;
            padding-left: 3%;
            padding-right: 3%;
            -webkit-overflow-scrolling: touch;
            scroll-behavior: smooth;
        }

        .category-pills::-webkit-scrollbar {
            height: 3px;
        }

        .category-pills::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
        }

        .category-pills::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 10px;
        }

        .pill { 
            padding: 7px 13px; 
            background: rgba(255, 255, 255, 0.05); 
            border: 1px solid transparent; 
            border-radius: 16px; 
            color: var(--text-muted); 
            cursor: pointer; 
            font-size: 12px; 
            white-space: nowrap;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .pill:active {
            background: rgba(255, 255, 255, 0.08);
        }

        .pill.active { 
            background: rgba(2, 249, 10, 0.2); 
            border-color: var(--primary); 
            color: var(--primary); 
            font-weight: 600; 
            box-shadow: 0 0 8px rgba(2, 249, 10, 0.2);
        }

        /* ===== TRACKING STEPPER ===== */
        .tracking-stepper { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            margin: 12px 0; 
            padding: 10px; 
            background: rgba(0, 0, 0, 0.3); 
            border-radius: 10px; 
            border: 1px solid rgba(2, 249, 10, 0.15);
            gap: 4px;
        }

        .step { 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            flex: 1; 
            position: relative;
            min-width: 50px;
        }

        .step .bullet { 
            width: 8px; 
            height: 8px; 
            border-radius: 50%; 
            background: #374151; 
            transition: 0.3s;
        }

        .step span { 
            font-size: 8px; 
            margin-top: 3px; 
            color: var(--text-muted);
            text-align: center;
        }

        .step.active .bullet { 
            background: var(--primary); 
            box-shadow: 0 0 8px var(--primary);
        }

        .step.active span { 
            color: var(--primary); 
            font-weight: bold;
        }

        /* ===== GRID PRODUCTS ===== */
        .grid-products { 
            display: grid; 
            grid-template-columns: repeat(2, 1fr); 
            gap: 10px;
            padding: 0 3%;
        }

        /* ===== CARD ===== */
        .card { 
            background: var(--bg-card); 
            border-radius: 12px; 
            padding: 12px; 
            border: 1px solid rgba(2, 249, 10, 0.1); 
            display: flex; 
            flex-direction: column; 
            justify-content: space-between;
            transition: all 0.2s ease;
            height: 100%;
        }

        .card:active {
            border-color: var(--primary);
            box-shadow: 0 0 12px rgba(2, 249, 10, 0.15);
            transform: scale(0.98);
        }

        .card img { 
            width: 100%; 
            height: 120px; 
            object-fit: contain; 
            margin-bottom: 10px;
        }

        .card h3 { 
            font-size: 13px; 
            font-weight: 700; 
            margin-bottom: 4px;
            line-height: 1.2;
        }

        .card p { 
            font-size: 11px; 
            color: var(--text-muted); 
            line-height: 1.2; 
            margin-bottom: 10px;
            flex: 1;
        }

        .card-footer { 
            display: flex; 
            justify-content: space-between; 
            align-items: flex-end; 
            margin-top: auto;
            gap: 6px;
        }

        .price { 
            font-size: 16px; 
            font-weight: 800; 
            color: var(--primary);
        }

        .card-actions {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 3px;
        }

        .card-stock {
            color: var(--success);
            font-size: 10px;
            font-weight: 600;
        }

        .card-stock.low {
            color: var(--danger);
        }

        /* ===== BUTTONS ===== */
        .btn { 
            background: var(--primary); 
            color: #000; 
            font-weight: 700; 
            padding: 9px 12px; 
            border-radius: 8px; 
            border: none; 
            cursor: pointer; 
            font-size: 12px; 
            transition: all 0.15s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 34px;
            user-select: none;
        }

        .btn:active { 
            transform: scale(0.96);
            box-shadow: 0 2px 8px rgba(2, 249, 10, 0.2);
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-danger { 
            background: var(--danger); 
            color: white;
        }

        .btn-success { 
            background: var(--success); 
            color: white;
        }

        /* ===== SIDE PANEL ===== */
        .side-panel { 
            display: none;
            flex-direction: column; 
            gap: 12px;
            padding: 12px 3%;
        }

        .side-panel.active {
            display: flex;
        }

        /* ===== PANEL BOX ===== */
        .panel-box { 
            background: var(--bg-card); 
            border-radius: 12px; 
            padding: 14px; 
            border: 1px solid rgba(2, 249, 10, 0.1); 
            backdrop-filter: blur(10px);
        }

        .panel-title { 
            font-size: 14px; 
            font-weight: 700; 
            margin-bottom: 12px; 
            display: flex; 
            align-items: center; 
            gap: 6px;
        }

        .panel-close-btn {
            margin-left: auto;
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: var(--text-main);
            cursor: pointer;
            font-size: 18px;
            width: 28px;
            height: 28px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ===== CART ITEMS ===== */
        .cart-item { 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            padding: 8px 0; 
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            gap: 6px;
        }

        .cart-item:last-child {
            border-bottom: none;
        }

        .cart-item-info { 
            flex: 1;
            min-width: 0;
        }

        .cart-item-info h4 { 
            font-size: 12px; 
            font-weight: 600;
            word-break: break-word;
            line-height: 1.2;
        }

        .cart-item-info span { 
            font-size: 10px; 
            color: var(--text-muted);
        }

        .cart-item-controls{
            display: flex;
            align-items: center;
            gap: 3px;
            flex-shrink: 0;
        }

        .cart-item-controls .btn {
            padding: 4px 8px;
            font-size: 11px;
            min-height: 28px;
            min-width: 28px;
        }

        #cartItemsContainer{
            max-height: 200px;
            overflow-y: auto;
            margin-bottom: 10px;
        }

        #cartItemsContainer::-webkit-scrollbar {
            width: 3px;
        }

        #cartItemsContainer::-webkit-scrollbar-thumb {
            background: var(--primary);
            border-radius: 3px;
        }

        /* ===== INPUT GROUP ===== */
        .input-group { 
            margin-bottom: 10px;
        }

        .input-group label { 
            display: block; 
            font-size: 10px; 
            color: var(--text-muted); 
            margin-bottom: 5px; 
            font-weight: 500;
        }

        .input-group input, 
        .input-group select { 
            width: 100%; 
            background: var(--bg-input); 
            border: 1px solid rgba(2, 249, 10, 0.2); 
            padding: 10px; 
            border-radius: 8px; 
            color: #fff; 
            outline: none;
            font-size: 13px;
        }

        .input-group input:focus, 
        .input-group select:focus { 
            border-color: var(--primary);
            box-shadow: 0 0 8px rgba(2, 249, 10, 0.15);
        }

        /* ===== MODAL ===== */
        #modalAuth { 
            display: none; 
            position: fixed; 
            inset: 0; 
            background: rgba(0, 0, 0, 0.9); 
            backdrop-filter: blur(8px); 
            z-index: 1000; 
            align-items: center; 
            justify-content: center;
            padding: 16px;
            overflow-y: auto;
        }

        #modalAuth > div {
            width: 100%;
            max-width: 100%;
            background: #0b1120;
            border-radius: 12px;
        }

        #modalCarrito {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(8px);
            z-index: 900;
            padding: 16px;
            overflow-y: auto;
        }

        #modalCarrito.active {
            display: flex;
            flex-direction: column;
        }

        #cartModalContent {
            background: #0b1120;
            border-radius: 12px;
            padding: 16px;
            max-height: 90vh;
            overflow-y: auto;
            width: 100%;
        }

        /* ===== GENERATED TICKET ===== */
        #generatedTicket { 
            background: white; 
            color: #000; 
            padding: 12px; 
            border-radius: 8px; 
            margin-top: 10px; 
            font-family: monospace; 
            font-size: 11px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.6);
            overflow-x: auto;
            line-height: 1.3;
        }

        /* ===== PROFILE PANEL ===== */
        #panelPerfilCliente {
            border-color: rgba(2, 249, 10, 0.2) !important;
        }

        #panelPerfilCliente .panel-title {
            color: var(--primary);
        }

        /* ===== UTILITY CLASSES ===== */
        .full-width {
            width: 100%;
        }

        .text-center {
            text-align: center;
        }

        .text-muted {
            color: var(--text-muted);
        }

        /* ===== DARK MODE SCROLLBAR ===== */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.03);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(2, 249, 10, 0.4);
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        /* ===== ACCESSIBILITY ===== */
        @media (prefers-reduced-motion: reduce) {
            * {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }

        /* ===== SMALL PHONES ===== */
        @media (max-width: 380px) {
            .logo {
                font-size: 14px;
            }

            .header-center {
                max-width: 120px;
            }

            .grid-products {
                grid-template-columns: repeat(2, 1fr);
            }

            .card {
                padding: 10px;
            }

            .card img {
                height: 100px;
            }

            .card h3 {
                font-size: 12px;
            }

            .price {
                font-size: 14px;
            }

            .pill {
                padding: 6px 11px;
                font-size: 11px;
            }
        }

        /* ===== LANDSCAPE MODE ===== */
        @media (max-height: 600px) {
            .grid-products {
                grid-template-columns: repeat(3, 1fr);
            }

            .card {
                padding: 10px;
            }

            .card img {
                height: 90px;
            }

            body {
                padding-bottom: 100px;
            }
        }
    </style>
</head>
<body>

    <header>
        <div class="logo">🧬 Mi<span>Farmacia</span></div>
        
        <div class="header-center">
            <label>📍</label>
            <select id="globalSucursalSelector" onchange="cambiarSucursalGlobal()">
                <option value="Sur">Sur-16</option>
                <option value="Norte">Norte</option>
            </select>
        </div>

        <div class="header-right">
            <span id="lblSaludo">Invitado</span>
            <button id="btnPerfilToggle" class="btn" style="background:rgba(255,255,255,0.05); color:white; display:none;" onclick="togglePanelPerfil()">⚙️</button>
            <button id="btnCarrito" class="btn" style="display:none;" onclick="abrirCarrito()">
                🛒
                <span class="cart-badge" id="cartCounter" style="display:none;">0</span>
            </button>
            <button id="btnAuth" class="btn" onclick="abrirModalAuth()">Sesión</button>
        </div>
    </header>

    <main class="main-container">
        
        <section class="catalog-section">
            <div class="search-box">
                <input type="text" id="txtBuscar" placeholder="🔍 Buscar medicamento" oninput="filtrarCatalogoCompleto()">
            </div>
            
            <div class="category-pills">
                <button class="pill active" onclick="filtrarPorCategoria('Todos', this)">Todos</button>
                <button class="pill" onclick="filtrarPorCategoria('Analgésico', this)">Analgésico</button>
                <button class="pill" onclick="filtrarPorCategoria('Antibiótico', this)">Antibiótico</button>
                <button class="pill" onclick="filtrarPorCategoria('Suplemento', this)">Suplemento</button>
                <button class="pill" onclick="filtrarPorCategoria('Cuidado Personal', this)">Cuidado</button>
            </div>

            <div id="panelPerfilCliente" class="panel-box" style="display:none;">
                <div class="panel-title">⚙️ Mis Datos</div>
                <div class="input-group">
                    <label>Teléfono</label>
                    <input type="tel" id="txtPrefTelefono" placeholder="5512345678">
                </div>
                <div class="input-group">
                    <label>Dirección</label>
                    <input type="text" id="txtPrefDireccion" placeholder="Calle, Número">
                </div>
                <div class="input-group">
                    <label>Favoritos</label>
                    <input type="text" id="txtPrefFavoritos" placeholder="PROD-1212, PROD-4411">
                </div>
                <button class="btn btn-success full-width" style="margin-bottom:10px; justify-content:center;" onclick="guardarDatosPerfilServidor()">💾 Guardar</button>
            </div>

            <div class="grid-products" id="catalogGrid"></div>
        </section>

        <section class="side-panel" id="sidePanel">
            
            <div class="panel-box">
                <div class="panel-title">
                    📦 Rastreo
                    <button class="panel-close-btn" onclick="cerrarSidePanel()">✕</button>
                </div>
                <div style="display:flex; gap:6px; margin-bottom:0;">
                    <input type="text" id="txtRastreoFolio" placeholder="Folio (FH-XXXXXX)" style="flex:1; min-width:0; padding:9px; background:var(--bg-input); border:1px solid rgba(2,249,10,0.2); border-radius:8px; color:#fff; font-size:12px; outline:none;">
                    <button class="btn" onclick="consultarRastreoInterno()" style="flex-shrink:0;">Buscar</button>
                </div>
                
                <div class="tracking-stepper" id="stepperVisual" style="display:none; margin-top:10px;">
                    <div class="step" id="st-pendiente"><div class="bullet"></div><span>Pendiente</span></div>
                    <div class="step" id="st-almacen"><div class="bullet"></div><span>Almacén</span></div>
                    <div class="step" id="st-ruta"><div class="bullet"></div><span>Ruta</span></div>
                    <div class="step" id="st-entregado"><div class="bullet"></div><span>Entregado</span></div>
                </div>

                <div id="panelStatusScreen" style="margin-top:10px; font-size:12px; text-align:center; color:var(--text-muted);">
                    Ingresa tu folio para rastrear.
                </div>
            </div>

        </section>

    </main>

    <!-- MODAL DEL CARRITO -->
    <div id="modalCarrito">
        <div id="cartModalContent">
            <div class="panel-title">
                🛒 Carrito de Compras
                <button class="panel-close-btn" onclick="cerrarCarrito()">✕</button>
            </div>
            <div id="sucursalCarritoBadge" style="font-size:11px; color:var(--primary); font-weight:700; margin-bottom:12px;">Comprando en: Sucursal Sur</div>
            <div id="cartItemsContainer"></div>
            <div style="display:flex; justify-content:space-between; margin-bottom:12px; font-weight:700; font-size:13px;">
                <span>Total:</span>
                <span id="lblTotalCart" style="color:var(--primary); font-size:16px;">$0.00</span>
            </div>
            
            <div id="checkoutForm" style="display:none;">
                <div class="input-group">
                    <label>Nombre Completo del Paciente</label>
                    <input type="text" id="orderNombre">
                </div>
                <div class="input-group">
                    <label>Domicilio Completo de Entrega</label>
                    <input type="text" id="orderDomicilio">
                </div>
                <div class="input-group">
                    <label>Método de Pago Preferido</label>
                    <select id="orderMetodoPago">
                        <option value="Efectivo">Efectivo al recibir</option>
                        <option value="Tarjeta">Terminal Portátil (Tarjeta)</option>
                    </select>
                </div>
                <button class="btn btn-success full-width" style="justify-content:center; margin-bottom:8px;" onclick="procesarOrdenCompraFinal()">🚀 Confirmar y Enviar Pedido</button>
            </div>
            <div id="checkoutAnonMessage" style="text-align:center; font-size:12px; color:var(--text-muted); padding:10px;">
                Debes tener una cuenta activa para procesar compras en la sucursal.
            </div>

            <div class="panel-box" id="ticketBlock" style="display:none; margin-top:12px;">
                <div class="panel-title">🎫 Comprobante de Respaldo Gráfico</div>
                <button class="btn full-width" style="margin-bottom:10px; justify-content:center;" onclick="downloadPNG()">Descargar Comprobante .PNG</button>
                <div id="generatedTicket" style="display:none;"></div>
            </div>
        </div>
    </div>

    <!-- MODAL DE AUTENTICACIÓN -->
    <div id="modalAuth" style="display:none;">
        <div class="panel-box">
            <div class="panel-title" id="authTitle">🔐 Autenticación de Paciente</div>
            
            <div id="loginFields">
                <div class="input-group">
                    <label>Correo Electrónico</label>
                    <input type="email" id="loginEmail">
                </div>
                <div class="input-group">
                    <label>Contraseña Secreta</label>
                    <input type="password" id="loginPass">
                </div>
                <button class="btn full-width" style="margin-bottom:12px; justify-content:center;" onclick="ejecutarIngresoBase()">Ingresar al Sistema</button>
                <p style="font-size:12px; text-align:center; color:var(--text-muted);">¿Eres nuevo? <a href="#" style="color:var(--primary); font-weight:700;" onclick="event.preventDefault(); conmutarAuthView(true)">Regístrate aquí</a></p>
            </div>

            <div id="registerFields" style="display:none;">
                <div class="input-group">
                    <label>Nombre Completo</label>
                    <input type="text" id="regNombre">
                </div>
                <div class="input-group">
                    <label>Correo Electrónico</label>
                    <input type="email" id="regEmail">
                </div>
                <div class="input-group">
                    <label>Contraseña</label>
                    <input type="password" id="regPass">
                </div>
                <button class="btn btn-success full-width" style="margin-bottom:12px; justify-content:center;" onclick="ejecutarRegistroBase()">Crear Mi Cuenta</button>
                <p style="font-size:12px; text-align:center; color:var(--text-muted);">¿Ya tienes cuenta? <a href="#" style="color:var(--primary); font-weight:700;" onclick="event.preventDefault(); conmutarAuthView(false)">Inicia sesión</a></p>
            </div>

            <button class="btn btn-danger full-width" style="margin-top:12px; justify-content:center; padding:8px;" onclick="cerrarModalAuth()">Cancelar</button>
        </div>
    </div>

    <script>
        // DOS LINKS GOOGLE SHEETS DIFERENTES (APPS SCRIPTS)
        const URL_BACKEND_SUR = "https://script.google.com/macros/s/AKfycbwj4HpBp8lCzHdHIgYeplAuUNJbpBzIcyYdgkjV2Y5snQJ7jsCiNQCYXtuDw1ijCKvw/exec"; 
        const URL_BACKEND_NORTE = "https://script.google.com/macros/s/AKfycbyNQFiZh-hWpzq8qtDaNkjMnH4S5ENJq2fKqd8xCt2_CzgkxPs9OqJnHPa9am3BYTJc/exec"; 

        let URL_BACKEND = URL_BACKEND_SUR;

        let dbProductos = [];
        let carrito = {};
        let sesionUsuario = null;
        let filtroCategoriaActual = "Todos";
        let sucursalSeleccionada = "Sur";

        window.onload = async () => {
            await descargarCatalogo();
            verificarCacheSesion();
        };

        async function cambiarSucursalGlobal() {
            sucursalSeleccionada = document.getElementById("globalSucursalSelector").value;
            document.getElementById("sucursalCarritoBadge").innerText = `Comprando en: Sucursal ${sucursalSeleccionada}`;
            
            if(sucursalSeleccionada === "Norte") {
                URL_BACKEND = URL_BACKEND_NORTE;
            } else {
                URL_BACKEND = URL_BACKEND_SUR;
            }

            carrito = {};
            actualizarGraficosCarrito();
            await descargarCatalogo();
        }

        async function descargarCatalogo() {
            try {
                let res = await fetch(`${URL_BACKEND}?action=productos`);
                dbProductos = await res.json();
                renderizarPantallaCatalogo(dbProductos);
            } catch(e) { console.error("Error cargando productos", e); }
        }

        function renderizarPantallaCatalogo(listado) {
            const grid = document.getElementById("catalogGrid");
            grid.innerHTML = "";
            if(listado.length === 0) {
                grid.innerHTML = `<p style="color:var(--text-muted); grid-column:1/-1;">No se encontraron medicamentos en Sucursal ${sucursalSeleccionada}.</p>`;
                return;
            }
            listado.forEach(p => {
                grid.innerHTML += `
                    <div class="card">
                        <img src="${p.imagen || 'https://via.placeholder.com/150'}" onerror="this.src='https://via.placeholder.com/150'" alt="${p.nombre}">
                        <div>
                            <h3>${p.nombre}</h3>
                            <p>${p.descripcion || 'Sin descripción'}</p>
                        </div>
                        <div class="card-footer">
                            <span class="price">$${Number(p.precio).toFixed(2)}</span>
                            <div class="card-actions">
                                <small class="card-stock ${p.stock <= 0 ? 'low' : ''}">Stock: ${p.stock}</small>
                                <button class="btn" ${p.stock <= 0 ? 'disabled' : ''} onclick="meterAlCarrito('${p.codigo}', '${p.nombre}', ${p.precio})">
                                    🛒
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
        }

        function filtrarCatalogoCompleto() {
            const txt = document.getElementById("txtBuscar").value.toLowerCase().trim();
            let resultado = dbProductos;

            if(filtroCategoriaActual !== "Todos") {
                resultado = resultado.filter(p => p.descripcion && p.descripcion.toLowerCase().includes(filtroCategoriaActual.toLowerCase()));
            }
            if(txt !== "") {
                resultado = resultado.filter(p => p.nombre.toLowerCase().includes(txt) || p.codigo.toLowerCase().includes(txt) || (p.descripcion && p.descripcion.toLowerCase().includes(txt)));
            }
            renderizarPantallaCatalogo(resultado);
        }

        function filtrarPorCategoria(cat, elemento) {
            document.querySelectorAll(".pill").forEach(b => b.classList.remove("active"));
            elemento.classList.add("active");
            filtroCategoriaActual = cat;
            filtrarCatalogoCompleto();
        }

        function meterAlCarrito(codigo, nombre, precio) {
            if(!sesionUsuario) { alert("Inicia sesión para poder estructurar tu carrito."); return; }
            if(carrito[codigo]) {
                carrito[codigo].qty++;
            } else {
                carrito[codigo] = { code: codigo, name: nombre, price: precio, qty: 1 };
            }
            actualizarGraficosCarrito();
        }

        function modificarCantidadCarrito(codigo, cambio) {
            if(!carrito[codigo]) return;
            carrito[codigo].qty += cambio;
            if(carrito[codigo].qty <= 0) delete carrito[codigo];
            actualizarGraficosCarrito();
        }

        function actualizarGraficosCarrito() {
            const container = document.getElementById("cartItemsContainer");
            container.innerHTML = "";
            let total = 0;
            let itemCount = 0;
            
            Object.values(carrito).forEach(p => {
                let sub = p.price * p.qty;
                total += sub;
                itemCount += p.qty;
                container.innerHTML += `
                    <div class="cart-item">
                        <div class="cart-item-info">
                            <h4>${p.name}</h4>
                            <span>$${p.price.toFixed(2)} x ${p.qty}</span>
                        </div>
                        <div class="cart-item-controls">
                            <button class="btn" onclick="modificarCantidadCarrito('${p.code}', -1)">−</button>
                            <button class="btn" onclick="modificarCantidadCarrito('${p.code}', 1)">+</button>
                        </div>
                    </div>
                `;
            });
            document.getElementById("lblTotalCart").innerText = `$${total.toFixed(2)}`;
            
            // Actualizar badge del carrito
            const cartBadge = document.getElementById("cartCounter");
            if(itemCount > 0) {
                cartBadge.textContent = itemCount;
                cartBadge.style.display = "flex";
            } else {
                cartBadge.style.display = "none";
            }
        }

        async function consultarRastreoInterno() {
            const folio = document.getElementById("txtRastreoFolio").value.trim();
            const pantalla = document.getElementById("panelStatusScreen");
            const stepper = document.getElementById("stepperVisual");
            
            if(!folio) return;
            pantalla.innerHTML = "Localizando transmisión del vehículo...";
            stepper.style.display = "none";
            
            try {
                let res = await fetch(`${URL_BACKEND}?action=pedidos`);
                let pedidos = await res.json();
                let p = pedidos.find(item => item.folio.toLowerCase() === folio.toLowerCase());
                
                if(p) {
                    stepper.style.display = "flex";
                    document.querySelectorAll(".step").forEach(s => s.classList.remove("active"));
                    
                    if(p.estado === "Pendiente") document.getElementById("st-pendiente").classList.add("active");
                    else if(p.estado === "En Almacén") { ["st-pendiente","st-almacen"].forEach(id=>document.getElementById(id).classList.add("active")); }
                    else if(p.estado === "En Ruta") { ["st-pendiente","st-almacen","st-ruta"].forEach(id=>document.getElementById(id).classList.add("active")); }
                    else if(p.estado === "Entregado") { ["st-pendiente","st-almacen","st-ruta","st-entregado"].forEach(id=>document.getElementById(id).classList.add("active")); }

                    let repartidorDato = (p.repartidor === "Sin asignar" || !p.repartidor) ? 
                        `<span style="color:var(--text-muted); font-size:11px;">Asignando operador en almacén...</span>` : 
                        `<div style="margin-top:8px; padding:10px; background:rgba(0,240,255,0.05); border-radius:6px; border:1px solid var(--primary);">
                            <b style="color:var(--primary);">🛵 Operador: ${p.repartidor}</b>
                            <p style="font-size:12px; color:var(--text-muted);">Va en camino directo a tu cuadrante.</p>
                         </div>`;

                    pantalla.innerHTML = `
                        <div style="text-align:left; margin-top:10px;">
                            <p><b>Sucursal:</b> ${sucursalSeleccionada}</p>
                            <p><b>Paciente:</b> ${p.cliente}</p>
                            <p><b>Dirección:</b> ${p.domicilio}</p>
                            <p><b>Estado:</b> <span style="color:var(--primary);">${p.estado}</span></p>
                            <p><b>Pago:</b> ${p.metodo_pago || 'Efectivo'}</p>
                            ${repartidorDato}
                        </div>
                    `;
                } else {
                    pantalla.innerHTML = `<span style="color:var(--danger)">Folio incorrecto o no registrado en la Sucursal ${sucursalSeleccionada}.</span>`;
                }
            } catch(e) { pantalla.innerHTML = "Error de sincronización."; }
        }

        async function procesarOrdenCompraFinal() {
            const nom = document.getElementById("orderNombre").value.trim();
            const dom = document.getElementById("orderDomicilio").value.trim();
            const pago = document.getElementById("orderMetodoPago").value;
            
            if(!nom || !dom) { alert("Completa los datos de despacho urgente."); return; }
            
            let arrProdStr = Object.values(carrito).map(x => `${x.name} (${x.qty}pz)`).join(", ");
            let totalGeneral = Object.values(carrito).reduce((a, b) => a + (b.price * b.qty), 0);
            
            let url = `${URL_BACKEND}?action=pedido&cliente=${encodeURIComponent(nom)}&correo=${encodeURIComponent(sesionUsuario.correo)}&domicilio=${encodeURIComponent(dom)}&productos=${encodeURIComponent(arrProdStr)}&metodo_pago=${encodeURIComponent(pago)}&total=${totalGeneral}&sucursal=${encodeURIComponent(sucursalSeleccionada)}`;
            
            try {
                let res = await fetch(url);
                let d = await res.json();
                if(d.ok) {
                    alert(d.msg + "\nFOLIO: " + d.folio + "\nSUCURSAL: " + sucursalSeleccionada);
                    document.getElementById("txtRastreoFolio").value = d.folio;
                    construirGraficoTicket(d.folio, nom, dom, totalGeneral);
                    carrito = {};
                    actualizarGraficosCarrito();
                    consultarRastreoInterno();
                }
            } catch(e) { alert("Error al procesar la orden."); }
        }

        function construirGraficoTicket(folio, nom, dom, total) {
            document.getElementById("ticketBlock").style.display = "block";
            const ticket = document.getElementById("generatedTicket");
            ticket.style.display = "block";
            
            let html = `
                <div style="text-align:center; font-weight:800; font-size:16px;">MI FARMACIA</div>
                <div style="text-align:center; font-size:11px; margin-bottom:10px;">COMPROBANTE DIGITAL - SUCURSAL ${sucursalSeleccionada.toUpperCase()}</div>
                <hr style="border:1px dashed #000; margin:6px 0;">
                <p><b>FOLIO:</b> ${folio}</p>
                <p><b>PACIENTE:</b> ${nom}</p>
                <p><b>DESTINO:</b> ${dom}</p>
                <p><b>FECHA:</b> ${new Date().toLocaleString()}</p>
                <hr style="border:1px dashed #000; margin:6px 0;">
            `;
            Object.values(carrito).forEach(x => {
                html += `<div style="font-size:12px;">${x.name} x ${x.qty} = $${(x.price*x.qty).toFixed(2)}</div>`;
            });
            html += `<hr style="border:1px dashed #000; margin:6px 0;"><h3 style="text-align:right;">TOTAL: $${total.toFixed(2)}</h3>`;
            ticket.innerHTML = html;
        }

        function downloadPNG() {
            const ticket = document.getElementById("generatedTicket");
            html2canvas(ticket).then(canvas => {
                const link = document.createElement("a");
                link.download = `Ticket_${document.getElementById("txtRastreoFolio").value}.png`;
                link.href = canvas.toDataURL("image/png");
                link.click();
            });
        }

        function togglePanelPerfil() {
            const p = document.getElementById("panelPerfilCliente");
            p.style.display = (p.style.display === "none") ? "block" : "none";
        }

        function abrirCarrito() {
            document.getElementById("modalCarrito").classList.add("active");
        }

        function cerrarCarrito() {
            document.getElementById("modalCarrito").classList.remove("active");
        }

        function cerrarSidePanel() {
            document.getElementById("sidePanel").classList.remove("active");
        }

        function abrirSidePanel() {
            document.getElementById("sidePanel").classList.add("active");
        }

        async function guardarDatosPerfilServidor() {
            const tel = document.getElementById("txtPrefTelefono").value.trim();
            const dir = document.getElementById("txtPrefDireccion").value.trim();
            const fav = document.getElementById("txtPrefFavoritos").value.trim();
            
            let url = `${URL_BACKEND}?action=actualizarPerfil&correo=${encodeURIComponent(sesionUsuario.correo)}&telefono=${encodeURIComponent(tel)}&direccion=${encodeURIComponent(dir)}&favoritos=${encodeURIComponent(fav)}`;
            let res = await fetch(url);
            let d = await res.json();
            alert(d.msg);
            if(d.ok) {
                sesionUsuario.telefono = tel;
                sesionUsuario.direccion = dir;
                sesionUsuario.favoritos = fav;
                localStorage.setItem("farma_user", JSON.stringify(sesionUsuario));
                autoacomodarCamposPerfil();
            }
        }

        function autoacomodarCamposPerfil() {
            if(sesionUsuario) {
                document.getElementById("orderNombre").value = sesionUsuario.nombre;
                document.getElementById("orderDomicilio").value = sesionUsuario.direccion || "";
                document.getElementById("txtPrefTelefono").value = sesionUsuario.telefono || "";
                document.getElementById("txtPrefDireccion").value = sesionUsuario.direccion || "";
                document.getElementById("txtPrefFavoritos").value = sesionUsuario.favoritos || "";
            }
        }

        function abrirModalAuth() {
            if(sesionUsuario) {
                localStorage.removeItem("farma_user");
                sesionUsuario = null;
                document.getElementById("lblSaludo").innerText = "Invitado";
                document.getElementById("btnAuth").innerText = "Iniciar Sesión";
                document.getElementById("btnCarrito").style.display = "none";
                document.getElementById("checkoutForm").style.display = "none";
                document.getElementById("checkoutAnonMessage").style.display = "block";
                document.getElementById("btnPerfilToggle").style.display = "none";
                document.getElementById("panelPerfilCliente").style.display = "none";
                carrito = {};
                actualizarGraficosCarrito();
                return;
            }
            document.getElementById("modalAuth").style.display = "flex";
        }
        
        function cerrarModalAuth() { 
            document.getElementById("modalAuth").style.display = "none"; 
        }
        
        function conmutarAuthView(verRegistro) {
            document.getElementById("loginFields").style.display = verRegistro ? "none" : "block";
            document.getElementById("registerFields").style.display = verRegistro ? "block" : "none";
            document.getElementById("authTitle").innerText = verRegistro ? "📝 Registro de Paciente Nuevo" : "🔐 Autenticación de Paciente";
        }

        async function ejecutarIngresoBase() {
            const em = document.getElementById("loginEmail").value.trim();
            const pas = document.getElementById("loginPass").value.trim();
            let res = await fetch(`${URL_BACKEND}?action=login&correo=${encodeURIComponent(em)}&password=${encodeURIComponent(pas)}`);
            let d = await res.json();
            alert(d.msg);
            if(d.ok) {
                establecerSesion(d.usuario);
                cerrarModalAuth();
            }
        }

        async function ejecutarRegistroBase() {
            const nom = document.getElementById("regNombre").value.trim();
            const em = document.getElementById("regEmail").value.trim();
            const pas = document.getElementById("regPass").value.trim();
            let res = await fetch(`${URL_BACKEND}?action=registro&nombre=${encodeURIComponent(nom)}&correo=${encodeURIComponent(em)}&password=${encodeURIComponent(pas)}&rol=Cliente`);
            let d = await res.json();
            alert(d.msg);
            if(d.ok) {
                establecerSesion(d.usuario);
                cerrarModalAuth();
            }
        }

        function establecerSesion(usr) {
            sesionUsuario = usr;
            localStorage.setItem("farma_user", JSON.stringify(usr));
            document.getElementById("lblSaludo").innerText = `Paciente: ${usr.nombre}`;
            document.getElementById("btnAuth").innerText = "🔒 Salir";
            document.getElementById("btnCarrito").style.display = "block";
            document.getElementById("checkoutForm").style.display = "block";
            document.getElementById("checkoutAnonMessage").style.display = "none";
            document.getElementById("btnPerfilToggle").style.display = "block";
            autoacomodarCamposPerfil();
        }

        function verificarCacheSesion() {
            let cache = localStorage.getItem("farma_user");
            if(cache) establecerSesion(JSON.parse(cache));
        }
    </script>
</body>
</html>
